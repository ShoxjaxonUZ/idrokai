# Groq API kaliti — loyihaning backend'i bilan AYNAN bir xil kalit.
# Bo'sh qoldirilsa, tizim avtomatik DRY (mock) rejimda ishlaydi — kalit shart emas.
GROQ_API_KEY=

# Ixtiyoriy sozlamalar (default qiymatlar ko'rsatilgan)
AGENT_MODEL=llama-3.3-70b-versatile
AGENT_TEMPERATURE=0.4
AGENT_MAX_TOKENS=2000
AGENT_MAX_FIX_ITER=1
