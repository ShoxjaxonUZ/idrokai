# ── Provayder: anthropic (default, Claude) yoki groq ──
AGENT_PROVIDER=anthropic

# Claude (Anthropic) API kaliti — LIVE rejim uchun.
# Bo'sh qoldirilsa, tizim avtomatik DRY (mock) rejimda ishlaydi — kalit shart emas.
ANTHROPIC_API_KEY=

# Groq kaliti — faqat AGENT_PROVIDER=groq bo'lganda kerak
GROQ_API_KEY=

# Barcha agentlar uchun default model (skill bo'yicha eng kuchli — Opus 4.8)
AGENT_MODEL=claude-opus-4-8

# ── HAR AGENTGA ALOHIDA MODEL ──────────────────────────────────────────────
# Default: hammasi AGENT_MODEL (claude-opus-4-8). Quyidagilarni ochib (#),
# har agentga BOSHQA model bering. Model tanlovi — SIZNING qaroringiz:
# kuchli ish uchun Opus, muvozanat uchun Sonnet, arzon/tez uchun Haiku.
# AGENT_MODEL_ORCHESTRATOR=claude-opus-4-8
# AGENT_MODEL_ARCHITECT=claude-opus-4-8
# AGENT_MODEL_PLANNER=claude-sonnet-4-6
# AGENT_MODEL_DEVELOPER=claude-opus-4-8
# AGENT_MODEL_SECURITY=claude-sonnet-4-6
# AGENT_MODEL_QA=claude-haiku-4-5
# AGENT_MODEL_SRE=claude-haiku-4-5
# AGENT_MODEL_FIX=claude-sonnet-4-6
# AGENT_MODEL_TECHWRITER=claude-haiku-4-5
# AGENT_MODEL_INTAKE=claude-haiku-4-5

# Fikrlash chuqurligi (Opus/Sonnet uchun, Haiku'da e'tiborsiz): low | medium | high | max
AGENT_EFFORT=high

# Boshqa sozlamalar
AGENT_MAX_TOKENS=8192
AGENT_MAX_FIX_ITER=1
