PORT=5000
JWT_SECRET=replace_with_random_64_byte_hex

# Lokal DB (cloud uchun DATABASE_URL ishlatiladi)
DB_USER=postgres
DB_PASSWORD=change_me
DB_HOST=localhost
DB_PORT=5432
DB_NAME=eduuz

# Production'da Render/Neon: DATABASE_URL=postgresql://user:pass@host/db?sslmode=require

ADMIN_EMAIL=admin@idrokai.uz
ADMIN_PASSWORD=change_me
GROQ_API_KEY=
CORS_ORIGIN=http://localhost:5173
APP_URL=http://localhost:5173

# Telegram xavfsizlik xabarlari
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Cloudflare R2 (production fayl saqlash)
# https://dash.cloudflare.com → R2 → Create bucket → API tokens
# Bo'sh qoldirsangiz: lokal disk (uploads/) ishlatiladi
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_URL=

# ═══════════════════════════════════════════════════════
# EMAIL — 2 ta variant. Bittasini tanlang.
# ═══════════════════════════════════════════════════════

# VARIANT 1 (TAVSIYA): Resend — eng oson, professional
# https://resend.com → Sign up (GitHub orqali)
# API Keys → Create API Key → kalitni nusxalang
# Bepul rejada: 3000 email/oy, faqat onboarding@resend.dev'dan yuboriladi
# Custom domen uchun: domen tasdiqlash kerak (DNS record)
RESEND_API_KEY=
RESEND_FROM=IdrokAI <onboarding@resend.dev>

# VARIANT 2: Gmail SMTP (bepul, lekin sozlash murakkabroq)
# 1) Google account: 2-Step Verification yoqilgan bo'lishi shart
# 2) https://myaccount.google.com/apppasswords → 16-belgili App Password
# 3) SMTP_USER = sizning gmail
# 4) SMTP_PASS = 16-belgili App Password (bo'shliqsiz)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=IdrokAI <noreply@idrokai.uz>
